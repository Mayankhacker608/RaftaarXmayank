{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install --prefix RaftaarX/backend && npm install --prefix RaftaarX/frontend",
  "buildCommand": "cd RaftaarX && npm run build",
  "builds": [
    {
      "src": "RaftaarX/backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "RaftaarX/frontend/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/RaftaarX/backend/server.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/RaftaarX/frontend/dist/index.html"
    }
  ]
}
